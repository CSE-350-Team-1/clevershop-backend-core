# Example environment variables for local development and docker-compose
# Copy this file to `.env` and fill in real values (DO NOT commit secrets).

# App
PORT=8000

# Database (example placeholders)
DBHOST=myclustername.postgres.cosmos.azure.com
DBNAME=my-db
DBUSER=your_db_user
DBPASSWORD=your_db_password
DBPORT=5432
